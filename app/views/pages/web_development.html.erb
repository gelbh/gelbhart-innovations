<div class="bg-secondary">
  <%= render "shared/breadcrumb" %>

  <div class="container py-2 py-md-3 px-3 px-sm-4">
    <h1 class="visually-hidden"><%= t("pages.services.web_development.page_title") %></h1>
    <h2 class="webdev-embed__section-title h5 text-body text-center mb-0" id="webdev-portfolio-embed-heading">
      <%= link_to "gelbhart.dev", AppConstants::PORTFOLIO_SITE_URL, class: "webdev-embed__section-domain link-primary", target: "_blank", rel: "noopener noreferrer" %><%= t("pages.services.web_development.embed_section_title_suffix") %>
    </h2>
  </div>

  <div class="webdev-embed" role="region" aria-labelledby="webdev-portfolio-embed-heading">
    <%= link_to services_path, class: "webdev-embed__back", data: { turbo_preload: true } do %>
      <i class="bx bx-arrow-back webdev-embed__back-icon" aria-hidden="true"></i><span class="d-none d-sm-inline"><%= t("pages.services.web_development.back_button") %></span><span class="d-sm-none"><%= t("common.back") %></span>
    <% end %>
    <iframe class="webdev-embed__frame"
            src="<%= AppConstants::PORTFOLIO_SITE_URL %>"
            title="<%= t("pages.services.web_development.embed_iframe_title") %>"
            allow="fullscreen"
            referrerpolicy="strict-origin-when-cross-origin"
            loading="lazy"></iframe>
  </div>
</div>
